<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/savedsong_selectall_iv"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="15dp"
        android:src="@drawable/btn_playlist_select_off"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/savedsong_selectall_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체 선택"
        android:textSize="15sp"
        android:textColor="@color/gray_color"
        app:layout_constraintTop_toTopOf="@id/savedsong_selectall_iv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_selectall_iv"
        app:layout_constraintStart_toEndOf="@id/savedsong_selectall_iv"/>


    <ImageView
        android:id="@+id/savedsong_listenall_iv"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="15dp"
        android:src="@drawable/ic_browse_arrow_right"
        app:layout_constraintTop_toTopOf="@id/savedsong_selectall_iv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_selectall_iv"
        app:layout_constraintStart_toEndOf="@id/savedsong_selectall_tv"/>

    <TextView
        android:id="@+id/savedsong_listenall_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체 듣기"
        android:textSize="15sp"
        android:textColor="@color/gray_color"
        app:layout_constraintTop_toTopOf="@id/savedsong_listenall_iv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_listenall_iv"
        app:layout_constraintStart_toEndOf="@id/savedsong_listenall_iv"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="편집"
        android:textSize="15sp"
        android:textColor="@color/black"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/savedsong_selectall_iv"
        app:layout_constraintBottom_toBottomOf="@id/savedsong_selectall_iv"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>