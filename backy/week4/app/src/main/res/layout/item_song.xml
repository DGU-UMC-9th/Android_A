<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/item_song_num_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01"
        android:textSize="15sp"
        android:textColor="@color/black"
        android:layout_marginStart="5dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/item_song_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="노래 이름"
        android:textSize="15sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/item_song_num_tv"
        app:layout_constraintTop_toTopOf="@id/item_song_num_tv"
        app:layout_constraintBottom_toBottomOf="@id/item_song_num_tv"/>

    <TextView
        android:id="@+id/item_song_singer_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가수 이름"
        android:textSize="15sp"
        android:textColor="@color/gray_color"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/item_song_title_tv"
        app:layout_constraintStart_toStartOf="@id/item_song_title_tv"/>

    <ImageView
        android:id="@+id/item_song_more_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_more"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/item_song_player_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_play"
        android:layout_marginEnd="5dp"
        app:layout_constraintEnd_toStartOf="@id/item_song_more_btn"
        app:layout_constraintTop_toTopOf="@id/item_song_more_btn"
        app:layout_constraintBottom_toBottomOf="@id/item_song_more_btn"/>
</androidx.constraintlayout.widget.ConstraintLayout>