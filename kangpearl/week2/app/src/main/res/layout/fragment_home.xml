<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <ImageView
            android:id="@+id/home_pannel_background_iv"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:src="@drawable/img_first_album_default"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/home_pannel_btn_nugu_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_mike"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintEnd_toStartOf="@+id/home_pannel_btn_tickets_iv"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/home_pannel_btn_tickets_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_ticket"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintEnd_toStartOf="@+id/home_pannel_btn_setting_iv"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/home_pannel_btn_setting_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/btn_main_setting"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/home_pannel_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="중독적인 케이팝"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_pannel_btn_nugu_iv"/>

        <ImageView
            android:id="@+id/home_pannel_btn_play_iv"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/btn_panel_play_large"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/home_pannel_btn_nugu_iv"/>

        <TextView
            android:id="@+id/home_album_info_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="총 102곡 2025.10.02"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@+id/home_pannel_album_img_iv"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:id="@+id/home_pannel_album_img_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/img_album_exp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/home_pannel_background_iv"/>

        <TextView
            android:id="@+id/home_pannel_album_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Butter"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="15dp"
            app:layout_constraintBottom_toTopOf="@+id/home_pannel_album_singer_tv"
            app:layout_constraintStart_toEndOf="@+id/home_pannel_album_img_iv"
            app:layout_constraintTop_toTopOf="@+id/home_pannel_album_img_iv"
            />

        <TextView
            android:id="@+id/home_pannel_album_singer_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BTS"
            android:textColor="@color/white"
            android:layout_marginStart="15dp"
            app:layout_constraintTop_toBottomOf="@+id/home_pannel_album_title_tv"
            app:layout_constraintStart_toEndOf="@+id/home_pannel_album_img_iv"
            app:layout_constraintBottom_toBottomOf="@+id/home_pannel_album_img_iv"/>

        <ImageView
            android:id="@+id/home_pannel_miniplayer_play_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="280dp"
            android:layout_marginTop="190dp"
            android:src="@drawable/btn_miniplayer_play"
            app:layout_constraintStart_toStartOf="@+id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"
            />

        <ImageView
            android:id="@+id/home_miniplayer_go_list_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="360dp"
            android:layout_marginTop="190dp"
            android:src="@drawable/btn_miniplayer_go_list"
            app:layout_constraintStart_toStartOf="@id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <ImageView
            android:id="@+id/home_miniplayer_next_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="320dp"
            android:layout_marginTop="190dp"
            android:src="@drawable/btn_miniplayer_next"
            app:layout_constraintStart_toStartOf="@id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <ImageView
            android:id="@+id/home_miniplayer_previous_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="240dp"
            android:layout_marginTop="190dp"
            android:src="@drawable/btn_miniplayer_previous"
            app:layout_constraintStart_toStartOf="@id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <TextView
            android:id="@+id/home_pannel_playing_now_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Butter\nBTS"
            android:textColor="@color/black"
            android:layout_marginStart="30dp"
            android:layout_marginTop="190dp"
            app:layout_constraintStart_toStartOf="@id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"
            />

        <ImageView
            android:id="@+id/home_home_select_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="50dp"
            android:layout_marginTop="230dp"
            android:src="@drawable/ic_bottom_home_select"
            app:layout_constraintStart_toStartOf="@+id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="13dp"
            android:layout_marginTop="45dp"
            android:text="홈"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="@id/home_home_select_iv"
            app:layout_constraintTop_toTopOf="@id/home_home_select_iv"/>

        <ImageView
            android:id="@+id/home_look_no_selct_iv"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="140dp"
            android:layout_marginTop="230dp"
            android:src="@drawable/ic_bottom_look_no_select"
            app:layout_constraintStart_toStartOf="@+id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="1dp"
            android:layout_marginTop="45dp"
            android:text="둘러보기"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="@+id/home_look_no_selct_iv"
            app:layout_constraintTop_toTopOf="@+id/home_look_no_selct_iv"/>

        <ImageView
            android:id="@+id/home_search_no_select_iv"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginStart="230dp"
            android:layout_marginTop="240dp"
            android:src="@drawable/ic_bottom_search_no_select"
            app:layout_constraintStart_toStartOf="@+id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@id/home_pannel_background_iv"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="1dp"
            android:layout_marginTop="35dp"
            android:text="검색"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="@+id/home_search_no_select_iv"
            app:layout_constraintTop_toTopOf="@+id/home_search_no_select_iv"/>

        <ImageView
            android:id="@+id/home_locker_no_select_iv"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="320dp"
            android:layout_marginTop="240dp"
            android:src="@drawable/ic_bottom_locker_no_select"
            app:layout_constraintStart_toStartOf="@+id/home_pannel_background_iv"
            app:layout_constraintTop_toBottomOf="@+id/home_pannel_background_iv"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="1dp"
            android:layout_marginTop="35dp"
            android:text="보관함"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="@+id/home_locker_no_select_iv"
            app:layout_constraintTop_toTopOf="@+id/home_locker_no_select_iv"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>










