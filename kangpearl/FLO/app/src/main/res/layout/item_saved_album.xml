<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/item_saved_album_cover_cv"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/item_saved_album_cover_iv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_album_exp2"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/item_saved_album_title_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="LILAC"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toEndOf="@id/item_saved_album_cover_cv"
        app:layout_constraintTop_toTopOf="@id/item_saved_album_cover_cv"
        app:layout_constraintEnd_toStartOf="@id/item_saved_album_more_iv"/>

    <TextView
        android:id="@+id/item_saved_album_singer_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아이유 (IU)"
        android:textSize="14sp"
        android:textColor="#a6a6a6"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="@id/item_saved_album_title_tv"
        app:layout_constraintTop_toBottomOf="@id/item_saved_album_title_tv"/>

    <ImageView
        android:id="@+id/item_saved_album_more_iv"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Switch
        android:id="@+id/item_saved_album_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toStartOf="@id/item_saved_album_more_iv"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>