<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp">

    <ImageView
        android:id="@+id/item_saved_song_cover_iv"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/img_album_exp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/item_saved_song_more_iv"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_player_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/item_saved_song_play_iv"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/btn_miniplayer_play"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toStartOf="@id/item_saved_song_more_iv"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/item_saved_song_title_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Butter"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/item_saved_song_cover_iv"
        app:layout_constraintStart_toEndOf="@id/item_saved_song_cover_iv"
        app:layout_constraintEnd_toStartOf="@id/item_saved_song_play_iv"/>

    <TextView
        android:id="@+id/item_saved_song_singer_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="방탄소년단"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/item_saved_song_title_tv"
        app:layout_constraintStart_toEndOf="@id/item_saved_song_cover_iv"
        app:layout_constraintEnd_toStartOf="@id/item_saved_song_play_iv"/>

</androidx.constraintlayout.widget.ConstraintLayout>