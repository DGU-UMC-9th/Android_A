<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:id="@+id/locker_saved_coverImg_iv"
        android:src="@drawable/img_album_exp2"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/locker_saved_title_tv"
        android:text="노래 이름"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/locker_saved_coverImg_iv"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/locker_saved_singer_tv"
        android:text="가수 이름"
        app:layout_constraintStart_toEndOf="@id/locker_saved_coverImg_iv"
        app:layout_constraintTop_toBottomOf="@id/locker_saved_title_tv"
        android:layout_marginTop="2dp"
        android:layout_marginStart="10dp"/>

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:id="@+id/locker_saved_play_iv"
        android:src="@drawable/btn_player_play"
        app:layout_constraintEnd_toStartOf="@id/locker_saved_more_iv"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="12dp"/>

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:id="@+id/locker_saved_more_iv"
        android:src="@drawable/btn_player_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="12dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>