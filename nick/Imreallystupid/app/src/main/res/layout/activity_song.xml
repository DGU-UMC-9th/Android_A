    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/song_startTime_tv"
        android:text="00:00"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/song_seekbar_sb"
        android:layout_marginStart="5dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/song_endTime_tv"
        android:text="60:00"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/song_seekbar_sb"
        android:layout_marginEnd="5dp"/>
>>>>>>> Stashed changes

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/song_linear2"
        app:layout_constraintTop_toBottomOf="@id/song_seekbar_sb"
        android:layout_marginTop="30dp"
        android:gravity="center">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_repeat_iv"
            android:src="@drawable/nugu_btn_repeat_inactive"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_previous_iv"
            android:src="@drawable/nugu_btn_skip_previous_32"
            android:layout_marginStart="20dp"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_play_iv"
            android:src="@drawable/nugu_btn_play_32"
            android:layout_marginStart="20dp"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_pause_iv"
            android:src="@drawable/btn_miniplay_pause"
            android:visibility="gone"
            android:layout_marginStart="20dp"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_next_iv"
            android:src="@drawable/nugu_btn_skip_next_32"
            android:layout_marginStart="20dp"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/song_random_iv"
            android:src="@drawable/nugu_btn_random_inactive"
            android:layout_marginStart="20dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/song_linear3"
        app:layout_constraintTop_toBottomOf="@id/song_linear2"
        android:layout_marginTop="90dp"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:id="@+id/song_instagram_iv"
            android:src="@drawable/btn_actionbar_instagram"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:id="@+id/song_related_iv"
            android:src="@drawable/btn_player_related"
            android:layout_marginStart="130dp"/>

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:id="@+id/song_more_iv"
            android:src="@drawable/btn_player_more"
            android:layout_marginStart="130dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
