<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txt_today_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:layout_marginTop="30dp"
        android:text="오늘 하루는 어땠나요?"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/txt_select_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginTop="5dp"
        android:text="감정우표를 선택해주세요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_today_tv"/>

    <ImageButton
        android:id="@+id/btn_yellow_ib"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="120dp"
        android:src="@drawable/yellow_foreground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="SpeakableTextPresentCheck"/>


        <TextView
            android:id="@+id/txt_yello_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="더 없이 행복한 하루였어요"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_yellow_ib"/>

    <ImageButton
        android:id="@+id/btn_blue_ib"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/blue_foreground"
        app:layout_constraintEnd_toEndOf="@+id/btn_yellow_ib"
        app:layout_constraintStart_toStartOf="@+id/btn_yellow_ib"
        app:layout_constraintTop_toBottomOf="@+id/btn_yellow_ib"
        tools:ignore="SpeakableTextPresentCheck"
        />

    <TextView
        android:id="@+id/txt_blue_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="들뜨고 흥분돼요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_blue_ib"/>


    <ImageButton
        android:id="@+id/btn_purple_ib"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/purple_foreground"
        app:layout_constraintEnd_toEndOf="@+id/btn_blue_ib"
        app:layout_constraintStart_toStartOf="@+id/btn_blue_ib"
        app:layout_constraintTop_toBottomOf="@+id/btn_blue_ib"
        tools:ignore="SpeakableTextPresentCheck"
        />

    <TextView
        android:id="@+id/txt_purple_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="평범한 하루였어요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_purple_ib"/>


    <ImageView
        android:id="@+id/btn_green_ib"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/green_foreground"
        app:layout_constraintEnd_toEndOf="@+id/btn_purple_ib"
        app:layout_constraintStart_toStartOf="@+id/btn_purple_ib"
        app:layout_constraintTop_toBottomOf="@+id/btn_purple_ib"
        tools:ignore="SpeakableTextPresentCheck"/>

    <TextView
        android:id="@+id/txt_green_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="생각이 많아지고 불안해요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_green_ib"/>

    <ImageButton
        android:id="@+id/btn_red_ib"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/red_foreground"
        app:layout_constraintEnd_toEndOf="@+id/btn_green_ib"
        app:layout_constraintStart_toStartOf="@+id/btn_green_ib"
        app:layout_constraintTop_toBottomOf="@+id/btn_green_ib"
        tools:ignore="SpeakableTextPresentCheck"/>

    <TextView
        android:id="@+id/txt_red_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="부글부글 화가 나요"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_red_ib"/>



</androidx.constraintlayout.widget.ConstraintLayout>









