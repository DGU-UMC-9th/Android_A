<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/locker_select_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체선택"
        android:textColor="#808080"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/locker_play_all_img_iv"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/icon_browse_arrow_right"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="@id/locker_select_all_tv"
        app:layout_constraintBottom_toBottomOf="@id/locker_select_all_tv"
        app:layout_constraintStart_toEndOf="@id/locker_select_all_tv"/>

    <TextView
        android:id="@+id/locker_play_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체듣기"
        android:textColor="#808080"
        app:layout_constraintTop_toTopOf="@id/locker_select_all_tv"
        app:layout_constraintBottom_toBottomOf="@id/locker_select_all_tv"
        app:layout_constraintStart_toEndOf="@id/locker_play_all_img_iv"/>

    <TextView
        android:id="@+id/locker_edit_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="편집"
        android:layout_marginEnd="20dp"
        android:textColor="#808080"
        app:layout_constraintTop_toTopOf="@id/locker_select_all_tv"
        app:layout_constraintBottom_toBottomOf="@id/locker_select_all_tv"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/locker_saved_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"  android:layout_marginTop="10dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_saved"
        app:layout_constraintTop_toBottomOf="@id/locker_select_all_tv"
        app:layout_constraintBottom_toBottomOf="parent"  app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>