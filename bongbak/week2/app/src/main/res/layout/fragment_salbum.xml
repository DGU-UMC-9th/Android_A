<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/locker_salbum_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체선택"
        android:textColor="#808080"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/locker_salbum_all_img_iv"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/icon_browse_arrow_right"
        app:layout_constraintBottom_toBottomOf="@id/locker_salbum_all_tv"
        app:layout_constraintStart_toEndOf="@id/locker_salbum_all_tv"
        app:layout_constraintTop_toTopOf="@id/locker_salbum_all_tv"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/locker_salbum_listen_all_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="4dp"
        android:text="전체듣기"
        android:textColor="#808080"
        app:layout_constraintBottom_toBottomOf="@id/locker_salbum_all_tv"
        app:layout_constraintStart_toEndOf="@id/locker_salbum_all_tv"
        app:layout_constraintTop_toTopOf="@id/locker_salbum_all_tv"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/locker_salbum_edit_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="편집"
        android:textColor="#808080"
        app:layout_constraintBottom_toBottomOf="@id/locker_salbum_listen_all_tv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/locker_salbum_listen_all_tv"
        app:layout_constraintVertical_bias="0.0" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/locker_salbum_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/locker_salbum_all_tv"
        app:layout_constraintVertical_bias="1.0"
        tools:listitem="@layout/item_salbum" />

</androidx.constraintlayout.widget.ConstraintLayout>